###############################################################################
# Default behavior: normalize line endings to LF on checkout
###############################################################################
* text=auto eol=lf

###############################################################################
# C# / .NET source files
###############################################################################
*.cs     text eol=lf diff=csharp
*.csproj text eol=lf
*.sln    text eol=lf
*.props  text eol=lf
*.targets text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.editorconfig text eol=lf

###############################################################################
# Binary files
###############################################################################
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.ico    binary
*.webp   binary
*.svg    text eol=lf
*.pdf    binary
*.zip    binary
*.nupkg  binary
*.snupkg binary
*.dll    binary
*.exe    binary
*.so     binary
*.dylib  binary
*.pdb    binary

###############################################################################
# Merge strategy for project files
###############################################################################
*.csproj  merge=union
*.sln     merge=union
